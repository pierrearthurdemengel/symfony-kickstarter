# Variables d'environnement du projet Symfony Kickstarter
# Copier ce fichier vers .env.local et adapter les valeurs.
# Le fichier .env.local n'est pas versionne.

###> symfony/framework-bundle ###
# Environnement : dev, test, prod
APP_ENV=dev
# Mode debug : 1 en dev, 0 en prod
APP_DEBUG=1
# Secret utilise pour la generation de tokens CSRF, etc.
# Generer une valeur unique avec : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGER_CETTE_VALEUR_EN_PRODUCTION
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# URL de connexion a PostgreSQL
# Format : postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BDD?serverVersion=16&charset=utf8
DATABASE_URL="postgresql://kickstarter:kickstarter@database:5432/kickstarter?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Transport des messages asynchrones
# Doctrine par defaut, remplacer par redis://redis:6379 ou amqp://guest:guest@rabbitmq:5672
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# DSN du serveur mail
# Mailpit en dev, remplacer par un vrai SMTP en prod
MAILER_DSN=smtp://mailpit:1025
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
# Chemin vers les cles JWT (generees avec make jwt-generate)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Passphrase des cles JWT
JWT_PASSPHRASE=CHANGER_CETTE_VALEUR
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
# Origines autorisees pour les requetes CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> redis ###
# URL de connexion a Redis (cache, sessions, messenger)
REDIS_URL=redis://redis:6379
###< redis ###
