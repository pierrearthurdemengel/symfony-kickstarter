# =============================================================
# Configuration de production
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================

# Environnement
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=<generer_avec_openssl_rand_hex_32>

# Base de donnees PostgreSQL
DATABASE_URL="postgresql://user:password@database:5432/kickstarter?serverVersion=16&charset=utf8"

# Redis (cache et sessions)
REDIS_URL=redis://redis:6379

# Mailer (adapter selon le fournisseur : SendGrid, Mailgun, SES, etc.)
MAILER_DSN=smtp://user:password@smtp.example.com:587

# JWT - Cles d'authentification
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=<generer_un_passphrase_securise>

# CORS (domaine de production uniquement)
CORS_ALLOW_ORIGIN='^https://votre-domaine\.com$'

# Sentry - Monitoring d'erreurs (optionnel)
# SENTRY_DSN=https://xxx@sentry.io/yyy

# Messenger (Redis pour le transport async en production)
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
